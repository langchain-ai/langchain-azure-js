{
  "name": "langchain-azure-js",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/langchain-ai/langchain-azure-js",
  "workspaces": [
    "langchain",
    "langchain-core",
    "libs/*",
    "examples",
    "docs/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/langchain-ai/langchain-azure-js.git"
  },
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "build": "turbo build --filter=\"!test-exports-*\"",
    "turbo:command": "turbo",
    "clean": "turbo clean",
    "format": "turbo format --concurrency=50",
    "format:check": "turbo format:check --concurrency=50",
    "lint": "turbo lint --concurrency=50",
    "lint:fix": "turbo lint:fix --concurrency=50",
    "test": "pnpm run test:unit",
    "test:unit": "turbo test --filter=\"!test-exports-*\"",
    "test:unit:ci": "turbo test:ci",
    "test:int": "pnpm run test:int:deps && turbo test:integration ; pnpm run test:int:deps:down",
    "release": "node release_workspace.js --workspace"
  },
  "author": "LangChain",
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.2",
    "@types/jest": "^29.5.3",
    "@types/semver": "^7",
    "commander": "^11.1.0",
    "dotenv": "^16.0.3",
    "lint-staged": "^13.1.1",
    "prettier": "^2.8.3",
    "semver": "^7.7.2",
    "turbo": "^2.9.14",
    "typescript": "~5.1.6"
  },
  "pnpm": {
    "overrides": {
      "dpdm@^3.12.0": "3.12.0",
      "lodash": ">=4.18.1",
      "js-yaml": ">=5.2.1",
      "semver": ">=7.5.2",
      "rollup": ">=4.59.0",
      "minimatch@^5.0.1": "5.1.8",
      "minimatch@^9.0.3": "9.0.7",
      "minimatch@9.0.3": "9.0.7",
      "minimatch@^9.0.4": "9.0.7",
      "glob@^10.2.2": "10.5.0",
      "glob@^10.3.7": "10.5.0",
      "glob@^10.3.10": "10.5.0",
      "@octokit/plugin-paginate-rest@11.3.1": ">=11.4.1",
      "brace-expansion@^2.0.1": "2.0.3",
      "brace-expansion@^5.0.2": "5.0.6",
      "langsmith": ">=0.6.0",
      "socks@^2.8.3": "2.8.9",
      "tmp@^0.0.33": "0.2.7",
      "uuid@^10.0.0": "11.1.1"
    },
    "patchedDependencies": {
      "dpdm@3.12.0": "patches/dpdm@3.12.0.patch"
    }
  }
}
